        private void MakeRowsResponsive()
        {
            flowLayoutPanel1.WrapContents = false;
            flowLayoutPanel1.AutoScroll = true;
            flowLayoutPanel1.HorizontalScroll.Enabled = false;
            flowLayoutPanel1.HorizontalScroll.Visible = false;
            int rowWidth = flowLayoutPanel1.ClientSize.Width
                           - SystemInformation.VerticalScrollBarWidth - 5;
            foreach (Control row in flowLayoutPanel1.Controls)
            {
                // ensure row is visible panel
                if (!(row is Panel)) continue;
                row.Width = rowWidth;
                row.Height = 60;

                Panel namePanel = row.Controls["panel13"] as Panel;
                Panel regPanel = row.Controls["panel16"] as Panel;
                Panel emailPanel = row.Controls["panel15"] as Panel;
                Panel actionPanel = row.Controls["panel14"] as Panel;

                int colWidth = Math.Max(120, rowWidth / 4);

                if (namePanel != null) { namePanel.Width = colWidth; namePanel.Dock = DockStyle.Left; namePanel.Padding = new Padding(8); }
                if (regPanel != null) { regPanel.Width = colWidth; regPanel.Dock = DockStyle.Left; regPanel.Padding = new Padding(8); }
                if (emailPanel != null) { emailPanel.Width = colWidth; emailPanel.Dock = DockStyle.Left; emailPanel.Padding = new Padding(8); }
                if (actionPanel != null) { actionPanel.Width = colWidth; actionPanel.Dock = DockStyle.Left; actionPanel.Padding = new Padding(8); }

                if (actionPanel != null)
                {
                    Button editbutton = actionPanel.Controls["button2"] as Button;
                    Button deletebutton = actionPanel.Controls["button3"] as Button;

                    if (editbutton != null)
                    {
                        editbutton.Width = Math.Max(40, colWidth / 3);
                        editbutton.Anchor = AnchorStyles.Left;
                    }

                    if (deletebutton != null)
                    {
                        deletebutton.Width = Math.Max(40, colWidth / 3);
                        deletebutton.Anchor = AnchorStyles.Left;
                    }
                }
            }
        }
