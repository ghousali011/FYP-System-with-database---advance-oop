        private async void loadStudentsData()
        {
            flowLayoutPanel1.Controls.Clear();
            List<FYPManagementSystem.Model.Student> students;
            // If search box is empty, load all students; otherwise search by name
            if (string.IsNullOrWhiteSpace(textBox1?.Text))
            {
                students = StudentDL.viewAllStudents();
            }
            else
            {
                string searchTerm = textBox1.Text.Trim();
                students = StudentDL.searchStudentbyName(searchTerm);
            }
            foreach (var student in students)
            {
                Panel row = ClonePanel(panel6);
                row.Visible = true;

                // Make a fixed-height responsive row
                row.AutoSize = false;
                row.Height = 60;
                int rowWidth = flowLayoutPanel1.ClientSize.Width - SystemInformation.VerticalScrollBarWidth - 5;
                if (rowWidth < 200) rowWidth = flowLayoutPanel1.ClientSize.Width - 20;
                row.Width = rowWidth;
                row.Margin = new Padding(0, 5, 0, 5);
                row.Anchor = AnchorStyles.Top | AnchorStyles.Left | AnchorStyles.Right;
                // Do not dock inside a FlowLayoutPanel; let FlowLayoutPanel position the rows
                row.Dock = DockStyle.None;
                row.Margin = new Padding(0, 5, 0, 5);



                Label StudentName = row.Controls.Find("label11", true).FirstOrDefault() as Label;
                Label RegistrationNo = row.Controls.Find("label7", true).FirstOrDefault() as Label;
                Label Email = row.Controls.Find("label10", true).FirstOrDefault() as Label;
                Label id = row.Controls.Find("label8", true).FirstOrDefault() as Label;
                if (StudentName != null) StudentName.Text = $"{student.person.FirstName} {student.person.LastName}";
                if (RegistrationNo != null) RegistrationNo.Text = student.RegistrationNo;
                if (Email != null) Email.Text = student.person.Email;
                if (id != null) id.Text = $"{student.person.id}";
                id.Visible = false;
                //row.Width = flowLayoutPanel1.ClientSize.Width;

                //row.AutoSize = false;
                //row.Margin = new Padding(0);
                //ResizeRow(row);

                flowLayoutPanel1.Controls.Add(row);
                resizepanels.Add(row);

                // Find the Edit button in the cloned row
                Button editButton = row.Controls.Find("button2", true).FirstOrDefault() as Button;

                if (editButton != null)
                {
                    editButton.Click += (s, e) =>
                    {
                        int studentId = Convert.ToInt32(student.person.id);
                        using (AddStudent addForm = new AddStudent(studentId))
                        {
                            if (addForm.ShowDialog() == DialogResult.OK)
                            {
                                MessageBox.Show("Student Updated Successfully");
                                loadStudentsData();
                            }
                        }
                    };
                }
                // delete student 
                Button deleteButton = row.Controls.Find("button3", true).FirstOrDefault() as Button;
                if (deleteButton != null)
                {
                    deleteButton.Click += (s, e) =>
                    {
                        int studentId = Convert.ToInt32(student.person.id);
                        if (MessageBox.Show("Are you sure?", "Confirm Delete", MessageBoxButtons.YesNo) == DialogResult.Yes)
                        {
                            if (StudentDL.removeStudent(studentId))
                            {
                                MessageBox.Show("Student deleted successfully");
                                loadStudentsData();
                            }
                            else
                                MessageBox.Show("Failed to delete student");
                        }
                    };
                }
            }
        }
        // default clonepanel method
        public Control CloneControl(Control source)
        {
            Control newCtrl = (Control)Activator.CreateInstance(source.GetType());

            newCtrl.Name = source.Name;
            newCtrl.Text = source.Text;
            newCtrl.Location = source.Location;
            newCtrl.Size = source.Size;
            newCtrl.Font = source.Font;
            newCtrl.BackColor = source.BackColor;
            newCtrl.ForeColor = source.ForeColor;
            newCtrl.Anchor = source.Anchor;
            newCtrl.AutoSize = source.AutoSize;
            newCtrl.Height = 60;

            foreach (Control child in source.Controls)
            {
                // Skip cloning ReportViewers or heavy controls
                if (child is FlowLayoutPanel) continue;
                Control clonedChild = CloneControl(child);
                if (clonedChild != null)
                {
                    // Make inner panels and labels responsive by docking where appropriate
                    if (clonedChild is Panel)
                    {
                        clonedChild.AutoSize = false;
                        clonedChild.Height = source.Height;
                    }
                    clonedChild.Anchor = AnchorStyles.Top | AnchorStyles.Left | AnchorStyles.Right;
                    newCtrl.Controls.Add(clonedChild);
                }
            }

            return newCtrl;
        }

        public Panel ClonePanel(Panel source)
        {
            return (Panel)CloneControl(source);
        }

